{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 1,
  "description": "Optional pinned assets for cache correctness Tier B. A backend remains disabled until its pin is populated with reviewed metadata and real checksums.",
  "assets": {
    "gguf": {
      "required": false,
      "pin": null
    },
    "mlx": {
      "required": false,
      "pin": null
    }
  },
  "pinSchema": {
    "required": [
      "architecture",
      "revision",
      "maxBytes"
    ],
    "ggufRequired": [
      "sha256"
    ],
    "mlxRequired": [
      "manifestSha256",
      "requiredFiles"
    ]
  }
}
